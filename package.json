{
  "name": "rn-expo-starter",
  "version": "2.0.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow bun",
    "prepare": "husky",
    "start": "expo start",
    "start:no-cache": "expo start --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "prettier:fix": "prettier '**/*.{js,jsx,ts,tsx,json,md}' --write",
    "check-types": "tsc --noEmit",
    "lint-format-fix": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
    "test": "jest",
    "test:debug": "jest -o --watch --coverage=false",
    "test:dev": "jest --watchAll --coverage=false --changedSince=origin/main",
    "test:updateSnapshots": "jest -u --coverage=false",
    "i18n:extract": "lingui extract",
    "i18n:compile": "lingui compile --typescript",
    "i18n:clean": "lingui extract --clean",
    "generate:color-token": "bun scripts/convert-colors.ts && prettier constants/theme-colors.ts --write && eslint constants/theme-colors.ts --fix"
  },
  "lint-staged": {
    "*.{js,ts,tsx,jsx}": "eslint --fix",
    "*.{js,css,md,ts,tsx,jsx}": "prettier --write"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "dependencies": {
    "@better-auth/expo": "^1.6.9",
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^5.2.2",
    "@lingui/core": "^6.0.0",
    "@lingui/format-po": "^6.0.0",
    "@lingui/react": "^6.0.0",
    "@lottiefiles/dotlottie-react": "^0.19.0",
    "@rn-primitives/label": "^1.4.0",
    "@rn-primitives/radio-group": "^1.4.0",
    "@rn-primitives/separator": "^1.4.0",
    "@rn-primitives/slot": "^1.4.0",
    "@tanstack/react-query": "^5.100.1",
    "better-auth": "^1.6.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "^55.0.17",
    "expo-constants": "~55.0.15",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.9",
    "expo-linking": "~55.0.14",
    "expo-localization": "~55.0.13",
    "expo-network": "~55.0.13",
    "expo-router": "~55.0.13",
    "expo-secure-store": "~55.0.13",
    "expo-splash-screen": "~55.0.19",
    "expo-status-bar": "~55.0.5",
    "expo-symbols": "~55.0.7",
    "expo-system-ui": "~55.0.16",
    "expo-web-browser": "~55.0.14",
    "hono": "^4.12.15",
    "lottie-react-native": "~7.3.6",
    "lucide-react-native": "^1.11.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.73.1",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-logs": "^5.6.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.4",
    "sonner": "^2.0.7",
    "sonner-native": "^0.24.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "uniwind": "^1.6.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@lingui/babel-plugin-lingui-macro": "^6.0.0",
    "@lingui/cli": "^6.0.0",
    "@lingui/metro-transformer": "^6.0.0",
    "@tanstack/eslint-plugin-query": "^5.100.1",
    "@testing-library/react-native": "^13.3.3",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-testing-library": "^7.16.2",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.16",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.3",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2"
  }
}
