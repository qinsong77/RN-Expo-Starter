{
  "name": "rn-expo-starter",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "preinstall": "npx only-allow bun",
    "prepare": "husky",
    "format": "eslint \"**/*.{js,jsx,ts,tsx}\" --fix && prettier \"**/*.{js,jsx,ts,tsx,json}\" --write",
    "lint": "eslint .",
    "lint:expo": "expo lint",
    "lint:fix": "eslint --fix .",
    "prettier:fix": "prettier '**/*.{js,jsx,ts,tsx,json,md}' --write",
    "start": "expo start",
    "start:no-cache": "expo start --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "generate:color-token": "bun scripts/convert-colors.ts && prettier constant/color.ts --write && eslint constant/color.ts --fix",
    "test": "jest",
    "test:debug": "jest -o --watch --coverage=false",
    "test:dev": "jest --watchAll --coverage=false --changedSince=origin/main",
    "test:updateSnapshots": "jest -u --coverage=false",
    "check-types": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{js,ts,tsx,jsx}": "eslint --fix",
    "*.{js,css,md,ts,tsx,jsx}": "prettier --write"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@lottiefiles/dotlottie-react": "^0.13.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "^54.0.27",
    "expo-constants": "~18.0.11",
    "expo-font": "~14.0.10",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.10",
    "expo-localization": "~17.0.8",
    "expo-router": "~6.0.17",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.12",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "i18next": "^25.2.1",
    "lottie-react-native": "~7.3.1",
    "lucide-react-native": "^0.525.0",
    "nativewind": "^4.1.23",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^15.1.1",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "sonner": "^2.0.5",
    "sonner-native": "^0.21.0",
    "tailwind-merge": "^3.0.1",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@babel/core": "^7.26.9",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@commitlint/types": "^19.8.0",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22",
    "@types/react": "~19.1.10",
    "eslint": "^9.30.",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-jest": "^29.0.1",
    "eslint-plugin-prettier": "^5.5.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-testing-library": "^7.5.3",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.14",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.13",
    "react-test-renderer": "19.0.0",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "enabled": true,
        "exclude": [
          "i18next",
          "@lottiefiles/dotlottie-react",
          "class-variance-authority",
          "sonner",
          "tailwindcss-animate"
        ],
        "listUnknownPackages": true
      }
    }
  }
}
